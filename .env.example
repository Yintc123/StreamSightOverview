# StreamSight — 根目錄 .env（Docker Compose 用）
# 複製為 .env 並填入實際值：
#   cp .env.example .env
#
# 注意事項：
#   1. Docker Compose env_file 不做 shell 展開、不脫單引號。
#      若值含特殊字元（$、空格）請勿加引號，直接寫裸值。
#   2. NEXT_PUBLIC_* 是 Next.js build-time 變數，修改後需重新 build image。
#   3. Docker 內各服務間的連線（DB_HOST、REDIS_HOST 等）由 compose 覆蓋為
#      container 名稱，此檔寫 localhost 供本機非 Docker 開發備用。

# ── 執行環境 ────────────────────────────────────────────────────
APP_ENV=local
APP_VERSION=0.0.0
APP_COMMIT=
APP_NAME=StreamSight

# ── 資料庫 (MariaDB) ────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=streamsight
DB_PASSWORD=streamsight
DB_NAME=streamsight
DB_ROOT_PASSWORD=root
# Backend (FastAPI SQLAlchemy dialect)
DB_DIALECT=mysql+asyncmy
# Go server connection pool
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=25
DB_CONN_MAX_IDLE_SEC=300
DB_CONN_MAX_LIFETIME_SEC=1800

# ── Redis ────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_USERNAME=
REDIS_DB=0
REDIS_TLS_ENABLED=0
# Frontend BFF session store
REDIS_KEY_PREFIX=streamsight-bff-dev
REDIS_CONNECT_TIMEOUT_MS=2000
REDIS_COMMAND_TIMEOUT_MS=1000

# ── Backend (FastAPI) ────────────────────────────────────────────
BACKEND_PORT=8000
# 至少 32 字元；產生方式：openssl rand -base64 48
ENCRYPTION_KEY=CHANGE_ME_min_32_chars_random_string_here
JWT_SECRET_KEY=CHANGE_ME_min_32_chars_random_secret_here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRY_SECONDS=1800
REFRESH_TOKEN_HASH_SECRET=CHANGE_ME_min_32_chars_random_pepper_here
REFRESH_TOKEN_EXPIRE_SECONDS=1209600
REFRESH_TOKEN_REUSE_GRACE_SECONDS=10
# 初始 super admin（LOCAL DEV 用明文密碼；prod 請換為 argon2id hash）
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_NAME=Administrator
INITIAL_ADMIN_PASSWORD=CHANGE_ME_strong_password
# Monitoring（Docker 內部由 compose 覆蓋）
MONITORING_INFRA_NODE_EXPORTER_URL=http://localhost:9100
MONITORING_INFRA_MYSQLD_EXPORTER_URL=http://localhost:9104

# ── Frontend (Next.js BFF) ───────────────────────────────────────
FRONTEND_PORT=3000
# Docker 內部由 compose 覆蓋為 http://backend:8000
BACKEND_API_URL=http://localhost:8000
USE_MOCK=0
# 至少 32 字元；產生方式：openssl rand -base64 48
SESSION_SECRET=CHANGE_ME_min_32_chars_random_secret_here
SESSION_COOKIE_NAME=streamsight_session
SESSION_COOKIE_DOMAIN=
SESSION_TTL_SECONDS=2592000
# Comma-separated；含 Streamlit URL 讓 logout POST 通過 Origin 檢查
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8501
STREAMLIT_BASE_URL=http://localhost:8501
# Build-time（修改後需重 build image）
NEXT_PUBLIC_APP_NAME=StreamSight
# '1' 顯示深/淺主題切換鈕；'0' 隱藏、固定淺色
NEXT_PUBLIC_ENABLE_THEME_TOGGLE=1

# ── Streamlit ────────────────────────────────────────────────────
STREAMLIT_PORT=8501
# Docker 內部由 compose 覆蓋為 http://frontend:3000 / http://backend:8000
BFF_BASE_URL=http://localhost:3000
FASTAPI_BASE_URL=http://localhost:8000
# 瀏覽器可達的 BFF 位址（登入重導 / TopBar 連結）；未設回退 BFF_BASE_URL。
# Docker 內部由 compose 覆蓋為 http://localhost:${FRONTEND_PORT}
BFF_PUBLIC_BASE_URL=http://localhost:3000
BFF_SESSION_PATH=/api/auth/session
BFF_LOGOUT_PATH=/api/auth/logout
BFF_LOGIN_PATH=/
BFF_CMS_PATH=/cms
STREAMLIT_ORIGIN=http://localhost:8501
ROLE_ADMIN_VALUE=1
ENABLE_THEME_TOGGLE=1
HTTP_CONNECT_TIMEOUT_SECONDS=3
HTTP_READ_TIMEOUT_SECONDS=10
HTTP_RETRY_MAX=2
HTTP_RETRY_BASE_SECONDS=0.2
HTTP_RETRY_FACTOR=2
REQUEST_ID_HEADER=X-Request-ID
REQUEST_ID_PREFIX=st
TOKEN_REFRESH_THRESHOLD_SECONDS=60
INTROSPECTION_CACHE_TTL_SECONDS=30

# ── Monitoring ports ────────────────────────────────────────────
NODE_EXPORTER_PORT=9100
MYSQLD_EXPORTER_PORT=9104
