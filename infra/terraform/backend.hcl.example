# Copy to backend.hcl and fill in. Safe to commit (no secrets).
# State locking is native to S3 (use_lockfile in versions.tf) — no DynamoDB.
# Create the bucket once before `terraform init` — see README.md.
bucket  = "streamsight-tfstate-CHANGEME"
key     = "streamsight/terraform.tfstate"
region  = "ap-northeast-1"
encrypt = true
