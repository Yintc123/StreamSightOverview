region      = "ap-northeast-1"
github_repo = "Yintc123/StreamSightOverview"

# --- Datastore credentials (required, sensitive) ---
# For CI these come from TF_VAR_* env vars / GitHub secrets instead of this file.
db_password      = "change-me"
db_root_password = "change-me-root"
redis_password   = "change-me-redis"

# --- Optional: SSH access to the datastore EC2 ---
# ssh_ingress_cidr = "1.2.3.4/32"
# key_pair_name    = "my-keypair"

# --- Optional sizing overrides ---
# ec2_instance_type = "t3.small"
# desired_count     = 1
# task_cpu          = 256
# task_memory       = 512
